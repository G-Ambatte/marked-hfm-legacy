{
  "name": "marked-hfm-legacy",
  "version": "1.0.0",
  "description": "Marked wrapper for Homebrewery-flavored Markdown - Legacy Edition",
  "main": "./lib/index.esm.js",
  "module": "./lib/index.esm.js",
  "browser": "./lib/index.umd.js",
  "type": "module",
  "keywords": [
    "marked",
    "extension",
    "homebrewery"
  ],
  "files": [
    "lib/",
    "src/"
  ],
  "scripts": {
    "build": "npm run build:esbuild",
    "build:esbuild": "node esbuild.config.js",
    "format": "eslint --fix",
    "lint": "eslint",
    "test": "npm run build:esbuild && node ./spec/test.config.js",
    "test:cover": "npm run build:esbuild && node --experimental-test-coverage ./spec/test.config.js -- --cover",
    "test:only": "npm run build:esbuild && node ./spec/test.config.js -- --only",
    "test:update": "npm run build:esbuild && node --test-update-snapshots ./spec/test.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/g-ambatte/marked-hfm-legacy.git"
  },
  "author": "G-Ambatte",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/g-ambatte/marked-hfm-legacy.git/issues"
  },
  "homepage": "https://github.com/g-ambatte/marked-hfm-legacy.git#readme",
  "dependencies": {
    "less": "^4.6.4",
    "marked": "^0.3.19"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@markedjs/eslint-config": "^1.0.14",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.0",
    "esbuild-plugin-umd-wrapper": "^3.0.0",
    "eslint": "^10.4.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  }
}
